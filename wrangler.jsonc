{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	// Worker name = the subdomain on *.workers.dev until a custom domain is set
	// (custom domain wiring is a Phase 7 task).
	"name": "knowledge-garden",
	"compatibility_date": "2026-07-15",
	"compatibility_flags": [
		// Required for postgres.js TCP connections + Node APIs on Workers.
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			// Self-reference service binding, the service name must match the worker name
			// see https://opennext.js.org/cloudflare/caching
			"binding": "WORKER_SELF_REFERENCE",
			"service": "knowledge-garden"
		}
	],
	"images": {
		// Enable image optimization
		// see https://opennext.js.org/cloudflare/howtos/image
		"binding": "IMAGES"
	},
	// Non-secret values are declared here; secrets (SUPABASE_SERVICE_ROLE_KEY,
	// DATABASE_URL) are set via `wrangler secret put <NAME>` and are NOT listed.
	// See .env.example for the full list and README "Getting started".
	"vars": {
		"NEXT_PUBLIC_SUPABASE_URL": "https://vrbutktnsdxgffoxnbul.supabase.co",
		"NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZyYnV0a3Ruc2R4Z2Zmb3huYnVsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQzODMyMzksImV4cCI6MjA5OTk1OTIzOX0.JJkI-t2L2QXdIAfzR2XYrMHoM7HTnWRsDy3MdPsshos"
	}
}
