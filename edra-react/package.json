{
  "name": "edra-react",
  "version": "0.1.0",
  "description": "Rich text editor for React, ported from Edra (Svelte). Built on Tiptap.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/editor.css": "./dist/styles/editor.css",
    "./styles/onedark.css": "./dist/styles/onedark.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node --input-type=module -e \"import{cpSync}from'fs';cpSync('src/styles','dist/styles',{recursive:true})\"",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@floating-ui/dom": "^1",
    "@radix-ui/react-dropdown-menu": "^1",
    "@radix-ui/react-popover": "^1",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-tabs": "^1",
    "@radix-ui/react-tooltip": "^1",
    "@tiptap/core": "^3",
    "@tiptap/extension-bubble-menu": "^3",
    "@tiptap/extension-code-block-lowlight": "^3",
    "@tiptap/extension-highlight": "^3",
    "@tiptap/extension-image": "^3",
    "@tiptap/extension-link": "^3",
    "@tiptap/extension-list": "^3",
    "@tiptap/extension-mathematics": "^3",
    "@tiptap/extension-placeholder": "^3",
    "@tiptap/extension-subscript": "^3",
    "@tiptap/extension-superscript": "^3",
    "@tiptap/extension-table": "^3",
    "@tiptap/extension-table-of-contents": "^3",
    "@tiptap/extension-text-align": "^3",
    "@tiptap/extension-text-style": "^3",
    "@tiptap/extension-typography": "^3",
    "@tiptap/markdown": "^3",
    "@tiptap/pm": "^3",
    "@tiptap/react": "^3",
    "@tiptap/starter-kit": "^3",
    "@tiptap/suggestion": "^3",
    "clsx": "^2",
    "katex": "^0.16",
    "lowlight": "^3",
    "lucide-react": "^0.400",
    "mermaid": "^11",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwind-merge": "^2"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.8.0",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-bubble-menu": "^3.28.0",
    "@tiptap/extension-code-block-lowlight": "^3.28.0",
    "@tiptap/extension-highlight": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-list": "^3.28.0",
    "@tiptap/extension-mathematics": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-subscript": "^3.28.0",
    "@tiptap/extension-superscript": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-table-of-contents": "^3.28.0",
    "@tiptap/extension-text-align": "^3.28.0",
    "@tiptap/extension-text-style": "^3.28.0",
    "@tiptap/extension-typography": "^3.28.0",
    "@tiptap/extensions": "^3.28.0",
    "@tiptap/markdown": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/suggestion": "^3.28.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "tailwind-merge": "^3.6.0",
    "tsup": "^8",
    "typescript": "^5.5"
  }
}
