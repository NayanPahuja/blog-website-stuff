# ---------------------------------------------------------------------------
# Personal Knowledge Garden — environment variables
#
# Copy this file to `.env.local` for local dev (Next.js loads it automatically).
# NEVER commit real secret values. For production (Cloudflare Workers) set
# secrets with `wrangler secret put <NAME>`; non-secret public values live in
# wrangler.jsonc under "vars".
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe for the browser; protected by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — bypasses RLS. SERVER ONLY, never expose to client.
# Used by src/lib/supabase/admin.ts for insert-only analytics writes.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string — MUST be the pooled (transaction-mode)
# connection: host `*.pooler.supabase.com`, port 6543.
# Example: postgresql://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Direct (port 5432) connections exhaust quickly from short-lived Workers (TRD §9).
DATABASE_URL=
